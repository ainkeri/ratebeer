<h1>Ratings</h1>

<div class="container text-center">
  <div class="row">
    <div class="col-sm-9">
      <div class="row">
        <div class="col-8 col-sm-6">
          <h2>Best beers</h2>
            <table class="table">
              <thead>
                <tr>
                  <th scope="col">Beer</th>
                  <th scope="col">Average</th>
                </tr>
              </thead>
              <tbody>
                <% @top_beers.each do |top_beer| %>
                  <tr>
                    <td><%= top_beer.name %></td>
                    <td><%= round(top_beer.average_rating) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
        </div>
        <div class="col-4 col-sm-6">
          <h2>Best breweries</h2>
            <table class="table">
              <thead>
                <tr>
                  <th scope="col">Brewery</th>
                  <th scope="col">Average</th>
                </tr>
              </thead>
              <tbody>
                <% @top_breweries.each do |top_brewery| %>
                  <tr>
                    <td><%= top_brewery.name %></td>
                    <td><%= round(top_brewery.average_rating) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
        </div>
      </div>
    </div>
  </div>
</div>

<h2>Most active users</h2>
<ol>
  <% @most_active_users.each do |most_active_user| %>
    <li><%= most_active_user.username %></li>
  <% end %>
</ol>

<h2>Recent ratings</h2>
<ul>
  <% @recent_ratings.each do |recent_rating| %>
    <li><%= recent_rating %> <%= link_to recent_rating.user.username, recent_rating.user %></li>
  <% end %>
</ul>

<%= link_to("New rating", new_rating_path, class:"btn btn-primary") if current_user %>